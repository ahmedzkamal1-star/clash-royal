# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Clash of Clans API Configuration
# Get your API key from https://developer.clashofclans.com/
# Make sure to register the IP address from which this app will run
COC_API_KEY=your_clash_of_clans_api_key_here
CLAN_TAG=#YOUR_CLAN_TAG

# Dashboard Configuration
PORT=3000
DASHBOARD_ADMIN_PASSWORD=admin12345
DATABASE_PATH=./src/db/clash_bot.db
